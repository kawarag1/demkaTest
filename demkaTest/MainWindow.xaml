<Window x:Class="demkaTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demkaTest"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Icon="/Images/icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#DAA520">
            <Image Source="/Images/icon.jpg" HorizontalAlignment="Left" Margin="10,0,0,0"/>
            <Button x:Name="BackBtn" Width="90" Height="30" Content="Назад" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="80,0,0,0" Click="BackBtn_Click"/>   
            <TextBlock x:Name="Header" Text="Авторизация" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
            <TextBlock x:Name="FIO" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center"/>
        </Grid>

        <Frame x:Name="FrmMain" Grid.Row="1" NavigationUIVisibility="Hidden" Navigated="FrmMain_Navigated"/>
    </Grid>
</Window>
