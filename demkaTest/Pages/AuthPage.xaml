<Page x:Class="demkaTest.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demkaTest.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage" Background="White">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <TextBlock Text="Логин" Margin="0,0,0,5"/>
            <TextBox x:Name="loginBox" Margin="0,0,0,10"/>
            <TextBlock Text="Пароль" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PwdBox" Margin="0,0,0,0"/>
            <Button Content="Войти" Click="Button_Click" Margin="10"/>
            <Button x:Name="ButtonGuest" Content="Войти как гость" Click="ButtonGuest_Click" Margin="10"/>
        </StackPanel>
    </Grid>
</Page>
