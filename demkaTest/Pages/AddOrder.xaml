<Page x:Class="demkaTest.Pages.AddOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demkaTest.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddOrder" Background="White">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Артикул"/>
            <TextBox x:Name="Article" Width="200"/>
            <Label Content="Статус заказа"/>
            <ComboBox x:Name="Statuses" Width="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label Content="Адрес пункта выдачи"/>
            <ComboBox x:Name="AddressBox" Width="200">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding postIndex}"/>
                            <TextBlock Text=", "/>
                            <TextBlock Text="{Binding city}"/>
                            <TextBlock Text=", "/>
                            <TextBlock Text="{Binding street}"/>
                            <TextBlock Text=" "/>
                            <TextBlock Text="{Binding houseNumber}"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label Content="Дата заказа"/>
            <DatePicker x:Name="CreateDate" FontFamily="Calibri"/>
            <Label Content="Дата выдачи"/>
            <DatePicker x:Name="DeliveryDate" FontFamily="Calibri"/>
            <Button x:Name="AddOrderBtn" Content="Добавить заказ" Margin="5" Click="AddOrderBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
