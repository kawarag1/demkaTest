<Page x:Class="demkaTest.Pages.EditProduct"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demkaTest.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditProduct" Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0">
            <Label Content="Артикул"/>
            <TextBox x:Name="ProductArticle" Width="160"/>
            <Label Content="Наименование"/>
            <TextBox x:Name="ProductName" Width="160"/>
            <Label Content="Цена"/>
            <TextBox x:Name="ProductCost" Width="160"/>
            <Label Content="Поставщик"/>
            <ComboBox x:Name="ProductSupplier">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label Content="Производитель"/>
            <ComboBox x:Name="ProductManufacturer">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label Content="Категория товара"/>
            <ComboBox x:Name="ProductCategory">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label Content="Скидка"/>
            <TextBox x:Name="ProductDiscount" Width="160"/>
            <Label Content="Количество на складе"/>
            <TextBox x:Name="ProductRemains" Width="160"/>
        </StackPanel>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Описание"/>
            <TextBox x:Name="ProductDescription" Width="300" Height="100" TextWrapping="Wrap" AcceptsReturn="True"/>
            <Border BorderThickness="1" BorderBrush="Black" MouseDown="ProductImage_MouseDown">
                <Image x:Name="ProductImage" Width="300" Height="200" Margin="0,10,0,10" MouseDown="ProductImage_MouseDown" />
            </Border>
            <Button x:Name="SaveBtn" Content="Сохранить изменения" Margin="0,10,0,0" Click="SaveBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
