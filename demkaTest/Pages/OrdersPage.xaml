<Page x:Class="demkaTest.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demkaTest.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Orders" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid x:Name="AdminPanel" Grid.Row="0" Background="#DAA520">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="AddOrder" Content="Добавить заказ" Margin="0,0,30,0" Width="160" Height="30" Click="AddOrder_Click"/>
                <Button x:Name="DeleteOrder" Content="Удалить заказ" Width="160" Height="30" Click="DeleteOrder_Click"/>
            </StackPanel>
        </Grid>
        
        <ListView x:Name="LViewOrders" Grid.Row="1" MouseDoubleClick="LViewOrders_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Width="600">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding id}" FontWeight="Bold" Grid.Row="0" />
                            <TextBlock Text="{Binding Statuses.name}" Grid.Row="1"/>
                            <StackPanel Orientation="Horizontal" Grid.Row="2">
                                <TextBlock Text="{Binding PickUpPoints.postIndex}"/>
                                <TextBlock Text=", "/>
                                <TextBlock Text="{Binding PickUpPoints.city}"/>
                                <TextBlock Text=", "/>
                                <TextBlock Text="{Binding PickUpPoints.street}"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding PickUpPoints.houseNumber}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CreateDate}" Grid.Row="3"/>

                            <Border BorderBrush="Black" BorderThickness="1" Margin="10" Grid.RowSpan="3"  Grid.Column="1">
                                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding DeliveryDate}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
