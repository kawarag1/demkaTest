<Page x:Class="demkaTest.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demkaTest.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <Grid x:Name="FilterPanel" Grid.Row="0" Background="#DAA520">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label Content="Количество на складе" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center"/>
            <Label Content="Цена" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"/>
            <Label Content="Действующая скидка" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center"/>
            <Label Content="Производитель" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center"/>
            <Label Content="Производитель" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" Grid.ColumnSpan="3"/>
            <TextBox x:Name="SearchBox" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" Grid.ColumnSpan="3" Width="240" TextChanged="SearchBox_TextChanged"/>


            <ComboBox x:Name="CountSort" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" Width="140" SelectionChanged="CountSort_SelectionChanged">
                <ComboBoxItem Content="По возрастанию"/>
                <ComboBoxItem Content="По убыванию"/>
            </ComboBox>

            <ComboBox x:Name="CostSort" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" Width="140" SelectionChanged="CostSort_SelectionChanged">
                <ComboBoxItem Content="По возрастанию"/>
                <ComboBoxItem Content="По убыванию"/>
            </ComboBox>

            <ComboBox x:Name="DiscountSort" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center" Width="140" SelectionChanged="DiscountSort_SelectionChanged">
                <ComboBoxItem Content="По возрастанию"/>
                <ComboBoxItem Content="По убыванию"/>
            </ComboBox>

            <ComboBox x:Name="ManufacturerSort" Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center" Width="140" SelectionChanged="ManufacturerSort_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <Grid x:Name="AdminPanel" Grid.Row="2" Background="#DAA520" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button x:Name="AddProduct" Content="Добавить" Click="AddProduct_Click"/>
            <Button x:Name="DeleteProduct" Content="Удалить" Grid.Column="1" Click="DeleteProduct_Click"/>
            <Button x:Name="Orders" Content="Заказы" Grid.Column="2" Click="Orders_Click" Visibility="Hidden"/>
        </Grid>

        <ListView x:Name="LViewMaterials" Grid.Row="1" MouseDoubleClick="LViewMaterials_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" BorderBrush="Black" Width="800">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderThickness="1" BorderBrush="Black">
                                <Image Source="{Binding photo}" Width="200" Height="100" Margin="5"/>
                            </Border>
                            
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Row="0">
                                    <TextBlock Text="{Binding Categories.name}" FontWeight="Bold"/>
                                    <TextBlock Text="|" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding name}" FontWeight="Bold"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="{Binding decs, StringFormat=Описание товара: {0}}"/>
                                <TextBlock Grid.Row="2" Text="{Binding Manufacturer.name, StringFormat=Производитель: {0}}"/>
                                <TextBlock Grid.Row="3" Text="{Binding Supplier.name, StringFormat=Поставщик: {0}}"/>
                                <TextBlock Grid.Row="4" Text="{Binding cost, StringFormat=Цена: {0}}"/>
                                <TextBlock Grid.Row="5" Text="{Binding Units.name, StringFormat=Единица измерения: {0}}"/>
                                <TextBlock Grid.Row="6" Text="{Binding remains, StringFormat=Количество на складе: {0}}"/>
                            </Grid>

                            <Border Grid.Column="2" BorderThickness="1" BorderBrush="Black">
                                <TextBlock Text="{Binding discountPercent, StringFormat=Скидка: {0}%}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
